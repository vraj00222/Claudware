# Copy to .env and fill in. NEVER commit .env (see .gitignore).
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
MESHGEN_API_KEY=
# Redis — reuse-before-regenerate (semantic generation cache + vector search) + agent memory + live
# stats. Key-gated: with NO url the app uses an in-memory fallback (zero-key boot). Use the FULL
# connection URL (not just a password): local `redis://localhost:6379`, or Redis Cloud
# `rediss://default:PASSWORD@HOST:PORT` (Redis Cloud > your DB > Connect > Redis client). Redis 8
# Vector Sets (VADD/VSIM) are used natively when present; otherwise KNN falls back to brute-force.
REDIS_URL=redis://localhost:6379
# Browserbase — model search (reuse-before-regenerate, sponsor #6). Server-only.
BROWSERBASE_API_KEY=
# Optional: only needed for the full Sessions API (not the Fetch API path).
BROWSERBASE_PROJECT_ID=
# The Token Company — prompt compression (sponsor). Compresses Claude prompts via bear-2
# to cut token costs. Key-gated: app works fine without it.
TTC_API_KEY=
# Real slicing (PrusaSlicer console mode) for "Prepare for print" → actual G-code + real time/grams.
# Binary-gated: install `prusa-slicer` (apt/AppImage/Homebrew) and it's auto-detected. Optional overrides:
#   SLICER_BIN   — explicit path to the slicer executable (if not on PATH / in known install locations)
#   ENABLE_SLICER=false — force the heuristic estimate even when a slicer IS installed
# With NO slicer installed the app falls back to the heuristic estimate (zero-tool demo path unchanged).
SLICER_BIN=
ENABLE_SLICER=
