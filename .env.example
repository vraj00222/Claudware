# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).
# The app works with ZERO keys — deterministic generation + localStorage + Web Speech.

# ── Core ──────────────────────────────────────────────────────────────────────
# Anthropic — the brain (Claude designs, classifies, clarifies, self-inspects)
ANTHROPIC_API_KEY=

# ── 3D Generation ─────────────────────────────────────────────────────────────
# NVIDIA NIM — TRELLIS text-to-3D for textured organic models (build.nvidia.com)
NVIDIA_NIM=

# ── Voice ─────────────────────────────────────────────────────────────────────
# Deepgram — speech-to-text (falls back to Web Speech API)
DEEPGRAM_API_KEY=

# ── Caching + Memory ──────────────────────────────────────────────────────────
# Redis — semantic generation cache + vector search + agent memory
# Key-gated: with NO url the app uses an in-memory fallback (zero-key boot).
# Local: redis://localhost:6379 · Cloud: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── Model Search ──────────────────────────────────────────────────────────────
# Browserbase — live web search of Printables + free model repos (server-only)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Token Savings ─────────────────────────────────────────────────────────────
# The Token Company — prompt compression via bear-2 (reduces Claude token costs)
TTC_API_KEY=

# ── Auth + Database + Storage ─────────────────────────────────────────────────
# InsForge — Google OAuth + per-user projects DB + model file storage
# Browser-side (public):
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Server-side (admin, never expose):
INSFORGE_URL=
INSFORGE_API_KEY=

# ── Slicing ───────────────────────────────────────────────────────────────────
# PrusaSlicer console mode — real G-code + real time/grams for "Prepare for print"
# Binary-gated: install prusa-slicer and it's auto-detected. Optional overrides:
#   SLICER_BIN     — explicit path to the slicer executable
#   ENABLE_SLICER  — set to false to force heuristic estimate even with slicer installed
SLICER_BIN=
ENABLE_SLICER=
